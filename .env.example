# =====================================================================
# Santec Group – Environment variables (NIGDY nie commituj prawdziwych wartości)
# Skopiuj ten plik do `.env.local` i uzupełnij. `.env.local` jest w .gitignore.
# Na Vercel ustaw te zmienne w Project Settings → Environment Variables.
# =====================================================================

# Publiczny URL strony (używany w SEO / sitemap / JSON-LD)
NEXT_PUBLIC_SITE_URL=https://santecgroup.ch

# Czy zezwolić wyszukiwarkom na indeksowanie (true/false).
# false  -> robots.txt: Disallow: /  +  meta robots: noindex,nofollow
# true   -> robots.txt: Allow: /     +  meta robots: index,follow
NEXT_PUBLIC_ALLOW_INDEXING=false

# Dane kontaktowe (publiczne – widoczne na stronie). Zmień przed wdrożeniem.
NEXT_PUBLIC_COMPANY_NAME=Santec Group GmbH
NEXT_PUBLIC_COMPANY_STREET=Alt-Ferrachstrasse 33b
NEXT_PUBLIC_COMPANY_ZIP=8630
NEXT_PUBLIC_COMPANY_CITY=Rüti ZH
NEXT_PUBLIC_COMPANY_COUNTRY=CH
NEXT_PUBLIC_COMPANY_PHONE=+41 79 787 73 477
NEXT_PUBLIC_COMPANY_EMAIL=adamzapala79@gmail.com

# === Sekrety (server-only, NIE używać prefiksu NEXT_PUBLIC_) ===
# Endpoint / API-key dostawcy maila (np. Resend, Sendgrid). Zostaw puste, żeby formularz
# pracował w trybie "log-only" (loguje do konsoli serwera, nic nie wysyła).
MAIL_PROVIDER_API_KEY=
MAIL_FROM=
MAIL_TO=
